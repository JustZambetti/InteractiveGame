  "events": {

    "intro": {
      "id": "intro",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The+Forest",
      "text": "You wake up in a dark forest, surrounded by tall trees. Where are you? Who are you? Your head hurts when you try to remember",
      "nextEventId": "apple"
    },

    "apple": {
      "id": "apple",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Apple?",
      "text": "You are sure about something. You are HUNGRY. For how much time have you been asleep? In front of you, hanging from a tree, you see an unfamiliar fruit.",
      "choices": [
        {
          "id": "choice_take_fruit",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You LOVE it! Cruncy and sweet at the same time.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Chewed+Fruit"
              },
              "nextEventId": "sword_1"
            }
          ]
        }
      ]
    },
    "sword_1": {
      "id": "sword_1",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The+Sword",
      "text": "You look around, trying to figure out what is happening to you, when your eyes are attracted by a sword. You feel a cold shiver down you spine...",
      "choices": [
        {
          "id": "choice_no_sword",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "Violence will not help you. You hand tries to reach the sword handle when you stop yourself and keep looking around.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Peace"
              },
              "nextEventId": "no_sword"
            }
          ]
        },
        {
          "id": "choice_yes_sword",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "Yes. Now you remember. You are a FEARLESS KNIGHT.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Sword"
              },
              "nextEventId": "crossroad"
            }
          ]
        }
      ]     
    },

    "no_sword": {
      "id": "no_sword",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Eyes in the dark",
      "text": "With looking around, you notice someting in the dark of the woods. Two eyes. Looking directly at you! You freeze.",
      "nextEventId": "no_sword_detour"
    },

    "no_sword_detour": {
      "id": "no_sword_detour",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Eyes in the dark",
      "text": "You retreat slowly. Your right hand is drawn to the sword. QUICK! YOU ARE IN DANGER!",
      "nextEventId": "no_sword_detour",
      "choices": [
        {
          "id": "choice_yes_sword_after_detour",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You take the sword. In an instant the staring eyes disappear. Was it real? Did the sword scare the creature away?",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Got sword"
              },
              "nextEventId": "crossroad"
            }
          ]
        }
      ]
    },

    "crossroad": {
      "id": "crossroad",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Crossroad",
      "text": "You look around. The sun is up, but how long before it's dark? You don't know. You notice you are in front of a crossroad. One path is full of brambles, while the other seems safer...",
      "choices": [
        {
          "id": "choice_easy_path",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You take the safer path. If brambles don't grow here, probably more peolpe are walking on it.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Peace"
              },
              "nextEventId": "forest_loop"
            }
          ]
        },
        {
          "id": "choice_hard_path",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "A strong knight makes strong choices. You don't fear plants. You take you sword and start clearing your way on the hard path. ",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Sword"
              },
              "nextEventId": "forest_loop"
            }
          ]
        }
      ]        
    },

    "forest_loop": {
      "id": "forest_loop",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Walking",
      "text": "You keep walking. Following the path. You have been walking for a lot.",
      "nextEventId": "forest_loop_sign"
    },

    "forest_loop_2": {
      "id": "forest_loop_2",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Walking",
      "text": "Yes, this must be the right direction!",
      "nextEventId": "forest_loop"
    },

     "forest_loop_sign": {
      "id": "forest_loop_sign",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Sign",
      "text": "A SIGN! But what does it say?",
      "choices": [
        {
          "id": "choice_read_sign",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You squint your eyes and try to read. It's clear, you need to turn left!",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Sign"
              },
              "nextEventId": "forest_loop_2"
            }
          ]
        },
        {
          "id": "choice_destroy_sign",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You don't need to read a gibberish sign to orient yourself in a forest. You take your sword and destroy the sign.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Sign"
              },
              "nextEventId": "destroyed_sign"
            }
          ]
        }
      ]        
    },

   "destroyed_sign": {
      "id": "destroyed_sign",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Bleeding Sign",
      "text": "Whait! Why is the sign... bleeding?",
      "nextEventId": "continue_walking"
    },

   "continue_walking": {
      "id": "continue_walking",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=Forest",
      "text": "It's a weird place, but it's getting dark, we cannot lose time on living objects. You continue walking",
      "nextEventId": "old_man"
    },

    "old_man": {
      "id": "old_man",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "You notice an old man resting on a staff. He turns his head and stares at you",
      "nextEventId": "old_man_2"
    },

    "old_man_2": {
      "id": "old_man_2",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "'I wasn't expecting to see you again...' he says",
      "choices": [
        {
          "id": "choice_gentle_old_man",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "'Have we met each other before?' 'It's been a long time, but I will never be able to forget you. But why are you here? You seem... lost.'",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The old man"
              },
              "nextEventId": "old_man_gentle"
            }
          ]
        },
        {
          "id": "choice_rude_old_man",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "'Who are you? How do I get out of the woods?!' You scream. The old man keep staring",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The old man"
              },
              "nextEventId": "old_man_3"
            }
          ]
        }
      ]    
    },

    "old_man_3": {
      "id": "old_man_3",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "The old man smiles at you in an uncanny way",
      "nextEventId": "old_man_4"
    },

    "old_man_4": {
      "id": "old_man_4",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "'This forest is surrounded by a river. Not water. But boiling pitch. And the smoke... it can confuse the mind.' Says the old man",
      "nextEventId": "old_man_5"
    },

    "old_man_5": {
      "id": "old_man_5",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "'Oh brave knight, the source of this river is located at the center of this forest, guarderd by a scary monster. Destroy the source and free us from this prison!'",
      "nextEventId": "old_man_6"
    },

    "old_man_6": {
      "id": "old_man_6",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The Old Man",
      "text": "'How to reach it? This forest is alive and it always change. You need to follow the mist. Find the source!'",
      "choices": [
        {
          "id": "choice_gentle_old_man_2",
          "label": "Heart",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "The old man points at a path. You take it.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The old man"
              },
              "nextEventId": "path_to_source_1"
            }
          ]
        },
        {
          "id": "choice_rude_old_man_2",
          "label": "Sword",
          "outcomes": [
            {
              "condition": null,
              "consequence": {
                "text": "You point your sword at the old man and try to attack him. 'WHAT'S GOING THROUGH YOUR HEAD?! We will see each other again, Wielburg...' Said the old man, disappearing into the woods. You take a deep breath and continue your walk.",
                "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The old man"
              },
              "nextEventId": "path_to_source_1"
            }
          ]
        }
      ]    
    },

    "path_to_source_1": {
      "id": "old_man_6",
      "image": "https://placehold.co/800x500/1a1714/e8e0d0?text=The path",
      "text": "",
      "nextEventId": "old_man_4"
    }

  }
}
